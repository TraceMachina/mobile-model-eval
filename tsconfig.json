{
  "extends": "./tsconfig.base.json",
  "include": [
    "index.ts",
    "harness/**/*.ts",
    "platforms/*.ts",
    "platforms/android/**/*.ts",
    "platforms/ios/**/*.ts",
    "scripts/**/*.ts",
    "widget/**/*.ts"
  ],
  "exclude": [
    "platforms/android/bridge/**/*",
    "platforms/ios/bridge/**/*",
    "platforms/shared/bridge/**/*",
    "node_modules",
    "results",
    "db",
    "dist",
    "out"
  ]
}
